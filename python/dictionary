text = "apple banana pineapple strawberry banana apple"

words = text.split()

frequency = {}
for word in words:
    if word in frequency:
        frequency[word] += 1
    else:
        frequency[word] = 1

print(frequency)

number_of_words = len(frequency)
print("Number of unique words:", number_of_words)



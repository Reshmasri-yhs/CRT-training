def calculate_squares(numbers, power=2):
    """
    Calculate the squares (or higher powers) of a list of numbers.

    Parameters:
    numbers (list): A list of numbers to be raised to the specified power.
    power (int): The exponent to which each number will be raised. Default is 2.

    Returns:
    list: A list of numbers raised to the specified power.
    """
    return [num ** power for num in numbers]
# Example usage:
numbers = [1, 2, 3, 4, 5]
squares = calculate_squares(numbers)
print(squares)  # Output: [1, 4, 9, 16, 25]

cubes = calculate_squares(numbers, power=3)
print(cubes)  # Output: [1, 8, 27, 64, 125]


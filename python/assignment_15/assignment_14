from collections import Counter

def is_valid_message(s):
    freq = Counter(s)
    counts = list(freq.values())
    
    # Already valid
    if len(set(counts)) == 1:
        return "YES"
    
    # Try removing one character
    for i in range(len(counts)):
        counts[i] -= 1
        if len(set(counts)) == 1 or all(c == counts[0] for c in counts):
            return "YES"
        counts[i] += 1  # restore
    
    return "NO"

s = input().strip()
print(is_valid_message(s))


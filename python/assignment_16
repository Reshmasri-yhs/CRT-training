n = int(input())
a = list(map(int, input().split()))

pos = a[0]              # max alternating sum ending here with current element as '+'
neg = float('-inf')     # max alternating sum ending here with current element as '-'

ans = pos

for i in range(1, n):
    new_pos = max(a[i], neg + a[i])
    new_neg = pos - a[i]

    pos, neg = new_pos, new_neg
    ans = max(ans, pos)

print(ans)
#Basic Example:
class Animal:
   def eat(self):
      print("Animal is eating")

#class class
class Dog(Animal):
   pass
d1 = Dog()
d1.eat()
'''
Dog class dose not contains eat()
 python searches for eat() in Dog class, if it does not find it there, it looks in the parent class (Animal) and finds it there, so it executes the eat() method from the Animal class.
 This is the basic idea of inheritance: a child class can use the methods and properties of its parent class, allowing for code reuse and a hierarchical relationship between classes.
 
'''
#no inheritance
class Dog:
   def eat(self):
      print("eating")
#with inheritance
class Animal:
   def eat(self):
      print("eating")
class Dog(Animal):
   pass
class cat(Animal):
   pass
c1 = cat()
c1.eat()
